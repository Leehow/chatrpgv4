{
  "source_note": "Authoritative weapon data from Keeper Rulebook Table XVII: Weapons (printed pages 401-405, PDF idx 412-416), transcribed from the rendered table pages. Covers every Table XVII row (104 weapons). Our weapons.json additionally carries two non-Table entries (unarmed, claws) which are intentionally absent here. Our weapons.json stores damage_die WITHOUT the +DB suffix (DB is handled by adds_damage_bonus). This ref stores the dice portion only, matching our convention. base_range_yards in yards (Touch=null). For 'half DB' weapons our data uses adds_damage_bonus=true with a special note.",
  "convention": {
    "damage_die": "dice portion only, DB suffix stripped (e.g. rulebook '1D8+DB' -> '1D8'); range-banded shotguns/explosives store the close-range band only ('4D6/2D6/1D6' -> '4D6'); 'Stun'-only cells store an empty string (our damage_die stays empty, damage_type=stun)",
    "base_range_yards": "integer yards, or null for Touch/melee; feet ranges (10 feet bullwhip, 15 feet taser, 6 feet mace) are null here with a note (our data stores the yard conversion); 'STR/5 yards' formula ranges store the literal string 'STR/5' (our data stores placeholder 5)",
    "malfunction": "integer (>=93) or null for melee",
    "magazine": "integer rounds or null; multi-value cells ('20/30/32') store the primary (first) value; 'One use' -> 1; 'Separate'/'Varies' -> null",
    "uses_per_round": "verbatim rulebook string",
    "eras": "rulebook era column mapped to ['1920s','modern'] subsets; 'Rare' (rare in all eras) -> ['1920s','modern'] with a note; 'WWII, Later' -> ['modern']",
    "note": "optional transcription note; not compared"
  },
