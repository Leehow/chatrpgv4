{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ruleset-neutral Runtime PublicState",
  "type": "object",
  "required": [
    "schema_version",
    "campaign_id",
    "play_language",
    "active_scene_id",
    "tension_level",
    "turn_number",
    "discovered_clue_ids",
    "actors",
    "investigators",
    "brain",
    "pending_choice",
    "terminal_evidence",
    "state_health"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer"
    },
    "campaign_id": {
      "type": "string"
    },
    "play_language": {
      "type": ["string", "null"]
    },
    "active_scene_id": {
      "type": ["string", "null"]
    },
    "tension_level": {
      "type": ["string", "null"]
    },
    "turn_number": {
      "type": "integer"
    },
    "discovered_clue_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actors": {
      "type": "array",
      "items": {"$ref": "#/$defs/actor"}
    },
    "investigators": {
      "type": "array",
      "description": "Compatibility alias of actors for existing CoC7 SDK consumers.",
      "items": {"$ref": "#/$defs/actor"}
    },
    "brain": {
      "type": "string",
      "enum": ["debug", "pi"]
    },
    "pending_choice": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["choice_id", "kind", "command_id", "responder", "revision", "prompt", "options"],
          "additionalProperties": false,
          "properties": {
            "choice_id": {"type": "string"},
            "kind": {"enum": ["push_confirm", "chase_action"]},
            "command_id": {"type": "string"},
            "responder": {"enum": ["player"]},
            "revision": {"type": "integer", "minimum": 0},
            "prompt": {"type": "string"},
            "options": {"$ref": "#/$defs/playerOptions"}
          }
        },
        {
          "type": "object",
          "required": ["choice_id", "kind", "command_id", "responder", "revision", "prompt", "options", "attack_id", "audience"],
          "additionalProperties": false,
          "properties": {
            "choice_id": {"type": "string"},
            "kind": {"enum": ["combat_defense"]},
            "command_id": {"type": "string"},
            "responder": {"enum": ["player"]},
            "revision": {"type": "integer", "minimum": 0},
            "prompt": {"type": "string"},
            "options": {"$ref": "#/$defs/playerOptions"},
            "attack_id": {"type": "string"},
            "audience": {"enum": ["player"]}
          }
        }
      ]
    },
    "terminal_evidence": {
      "type": "object",
      "required": ["reached_terminal", "active_scene_id", "graph_terminal", "session_ending"],
      "additionalProperties": false,
      "properties": {
        "reached_terminal": {"type": "boolean"},
        "active_scene_id": {"type": ["string", "null"]},
        "graph_terminal": {"type": "boolean"},
        "session_ending": {"type": "boolean"}
      }
    },
    "state_health": {
      "type": "object",
      "required": ["status", "issues"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "degraded", "error"]
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["state", "code"],
            "additionalProperties": false,
            "properties": {
              "state": {"type": "string", "enum": ["campaign", "world", "pacing", "actor", "investigator", "subsystem", "combat", "sanity", "chase", "terminal"]},
              "code": {"type": "string", "enum": ["missing", "corrupt", "invalid_utf8", "invalid_json", "non_object", "forward_version", "invalid_schema", "invalid_fields", "invalid_identifier"]}
            }
          }
        }
      }
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "required": ["id", "resources", "conditions"],
      "properties": {
        "id": {"type": "string"},
        "resources": {
          "type": "object",
          "additionalProperties": {"type": ["integer", "null"]}
        },
        "conditions": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "patternProperties": {
        "^current_[a-z][a-z0-9_]*$": {"type": ["integer", "null"]}
      },
      "additionalProperties": false
    },
    "playerOptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action", "label"],
        "additionalProperties": false,
        "properties": {
          "action": {"type": "string"},
          "label": {"type": "string"}
        }
      }
    }
  }
}
