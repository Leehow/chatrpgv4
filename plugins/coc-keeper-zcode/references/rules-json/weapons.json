    "base_range_yards": "close/standard range in yards; null for touch-only melee",
    "uses_per_round": "string describing attacks per round (e.g. '1', '1 (3)', '1/2', '1 or full auto')",
    "magazine": "rounds held; null for melee or non-magazine weapons",
    "malfunction": "malfunction number; attack roll >= this jams the weapon; null if none",
    "impales": "true if the weapon impales on an Extreme success",
    "adds_damage_bonus": "true for melee (adds attacker DB); false for firearms",
    "special": "short note for stun/burn/burst/throw rules, or null",
    "eras": "subset of ['1920s','modern'] in which the weapon is commonly available; rare weapons use ['rare']",
    "range_banded_damage": "shotguns only: {point_blank, half, max} damage at close/half/max range"
  },
