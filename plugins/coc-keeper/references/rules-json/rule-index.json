        "edu_improvement_die": "1D100",
        "edu_improves_if_roll_gt_current_edu": true,
        "edu_improvement_amount": "1D10",
        "edu_maximum": 99
      }
    },
    {
      "id": "core.character_creation.half_fifth_values",
