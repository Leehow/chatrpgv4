{
  "source_note": "Keeper Rulebook percentile bonus and penalty dice use one units die plus extra tens dice; bonus selects the lowest tens digit and penalty selects the highest tens digit.",
  "applies_to": "percentile-check",
  "cancellation": {
    "method": "one_for_one",
    "net_bonus_formula": "max(0, bonus - penalty)",
    "net_penalty_formula": "max(0, penalty - bonus)"
  },
  "bonus_die": {
    "extra_tens_dice_per_die": 1,
    "selected_tens": "lowest",
    "uses_same_units_die": true
  },
  "penalty_die": {
    "extra_tens_dice_per_die": 1,
    "selected_tens": "highest",
    "uses_same_units_die": true
  }
}
