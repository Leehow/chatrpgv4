{
  "source_note": "Keeper Rulebook Table XVII: Weapons (pp.401-405). Each row maps a canonical weapon to its skill, damage expression (excluding the attacker's damage bonus), base range in yards (null for melee/touch), uses per round, magazine capacity (null when not applicable), malfunction number (null when not applicable), whether it impales on an Extreme success, a special note, and the eras in which it is commonly available. Melee weapons add the attacker's damage bonus (adds_damage_bonus=true); firearms do not. Shotguns use range_banded_damage giving the close/half-range/max-range damage. Source: chapter 16 appendices, pp.401-405.",
  "schema": {
    "name": "weapon key, ASCII snake_case",
    "display_name": "canonical printable name",
    "skill": "skill used to attack (e.g. Fighting (Brawl), Firearms (Handgun))",
    "damage_die": "dice expression WITHOUT damage bonus; engine appends DB when adds_damage_bonus is true",
    "base_range_yards": "close/standard range in yards; null for touch-only melee",
    "uses_per_round": "string describing attacks per round (e.g. '1', '1 (3)', '1/2', '1 or full auto')",
    "magazine": "rounds held; null for melee or non-magazine weapons",
    "reload_rounds": "combat rounds to fully reload (1=clip/shells; 2=MG belt); derived if omitted",
    "reload_kind": "clip | shells | belt; derived from skill/magazine if omitted",
    "ammo_per_reload_round": "rounds restored per spent reload round; derived if omitted",
    "malfunction": "malfunction number; attack roll >= this jams the weapon; null if none",
    "impales": "true if the weapon impales on an Extreme success",
    "adds_damage_bonus": "true for melee (adds attacker DB); false for firearms",
    "special": "short note for stun/burn/burst/throw rules, or null",
    "eras": "subset of ['1920s','modern'] in which the weapon is commonly available; rare weapons use ['rare']",
    "range_banded_damage": "shotguns only: {point_blank, half, max} damage at close/half/max range"
  },
