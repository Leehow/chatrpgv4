        "fields_extracted",
        "fields_not_authored",
        "absence_receipt"
      ],
      "authored_required": [
        "profile",
        "source_refs",
        "fields_observed",
        "fields_extracted",
        "fields_not_authored",
        "provenance"
      ],
      "fields_accounting": {
        "actor_closed_field_ids": [
          "characteristics.STR",
          "characteristics.CON",
          "characteristics.SIZ",
          "characteristics.DEX",
          "characteristics.INT",
          "characteristics.APP",
          "characteristics.POW",
