          "spells",
          "san_loss_to_see",
          "armor",
          "armor_rule"
        ],
        "rules": [
          "fields_observed: closed-schema fields explicitly seen in the reviewed source block",
          "fields_extracted: observed fields normalized into the profile",
          "fields_not_authored: closed-schema fields absent from that source block",
          "fields_observed == fields_extracted",
          "fields_observed ∩ fields_not_authored = ∅",
          "fields_observed ∪ fields_not_authored == closed actor schema",
          "empty fields_extracted / fields_not_authored allowed when logically valid",
          "empty skills/weapons/attacks/spells containers do not count as extracted",
          "unknown ids rejected in all three sets",
          "do not fabricate fields the source did not author; mark them fields_not_authored"
        ]
      },
      "actor_profile": {
