#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PACKAGE_ROOT="$(cd "$PLUGIN_ROOT/../.." && pwd)"

# Grok starts plugin MCP servers with the opened workspace as cwd, but does not
# inject its hook-only workspace variables into MCP children. Resolve only a
# directory that carries the repository runtime contract; never treat the
# managed plugin cache as a campaign project.
if [[ -z "${COC_PROJECT_ROOT:-}" || ! -d "${COC_PROJECT_ROOT}/runtime" ]]; then
  unset COC_PROJECT_ROOT
  if [[ -n "${GROK_WORKSPACE_ROOT:-}" && -d "${GROK_WORKSPACE_ROOT}/runtime" ]]; then
    export COC_PROJECT_ROOT="$GROK_WORKSPACE_ROOT"
  elif [[ -n "${CLAUDE_PROJECT_DIR:-}" && -d "${CLAUDE_PROJECT_DIR}/runtime" ]]; then
    export COC_PROJECT_ROOT="$CLAUDE_PROJECT_DIR"
  elif [[ -f "$PWD/uv.lock" && -d "$PWD/runtime" ]]; then
    export COC_PROJECT_ROOT="$PWD"
  fi
fi

# The plugin package owns keeper skills and toolbox behavior; the repository's
# shared headless runtime remains the single compiler/runtime source. When the
# host installs a managed plugin copy, pass the opened workspace runtime back
# explicitly instead of deriving it from the managed plugin cache path.
if [[ -n "${COC_PROJECT_ROOT:-}" && -d "${COC_PROJECT_ROOT}/runtime" ]]; then
  export COC_RUNTIME_ROOT="${COC_PROJECT_ROOT}/runtime"
elif [[ -d "$PACKAGE_ROOT/runtime" ]]; then
  export COC_RUNTIME_ROOT="$PACKAGE_ROOT/runtime"
fi

if [[ -n "${COC_PROJECT_ROOT:-}" && -f "${COC_PROJECT_ROOT}/uv.lock" ]]; then
  exec uv run --project "$COC_PROJECT_ROOT" --frozen python "$PLUGIN_ROOT/mcp/server.py"
fi

# The repository-root Pi Package ships the exact Python project and lockfile.
# A clean installation must execute against that frozen packaged project while
# retaining the opened campaign directory as cwd; never bypass its uv.lock.
if [[ -f "$PACKAGE_ROOT/pyproject.toml" && -f "$PACKAGE_ROOT/uv.lock" ]]; then
  exec uv run --project "$PACKAGE_ROOT" --frozen python "$PLUGIN_ROOT/mcp/server.py"
fi

exec uv run --python 3.14.6 --no-project python "$PLUGIN_ROOT/mcp/server.py"
