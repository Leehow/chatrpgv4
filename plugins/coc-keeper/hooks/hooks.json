{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run\"",
            "env": {"COC_HOOK_EVENT": "session_start"},
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run\"",
            "env": {"COC_HOOK_EVENT": "user_prompt_submit"},
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run\"",
            "env": {"COC_HOOK_EVENT": "pre_compact"},
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run\"",
            "env": {"COC_HOOK_EVENT": "post_compact"},
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run\"",
            "env": {"COC_HOOK_EVENT": "session_end"},
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "coc[-_]keeper|MCPTool|CallMcpTool|use_tool|Bash|run_terminal_command|Edit|Write|MultiEdit|search_replace|Read|read_file",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/run\"",
            "env": {"COC_HOOK_EVENT": "pre_tool_use"},
            "timeout": 10
          }
        ]
      }
    ]
  }
}
