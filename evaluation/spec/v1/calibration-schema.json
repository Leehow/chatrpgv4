{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatrpgv4.local/evaluation/spec/v1/calibration-schema.json",
  "title": "COC Evaluation Human Calibration Reviews v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "eval_spec",
    "rubric_id",
    "rubric_version",
    "reviews"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "eval_spec": {"const": "eval-spec-v1"},
    "rubric_id": {"type": "string", "minLength": 1},
    "rubric_version": {"type": "string", "minLength": 1},
    "request_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/review_item"}
    }
  },
  "$defs": {
    "review_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item_id",
        "reviewer_id",
        "rubric_id",
        "rubric_version",
        "decision",
        "evidence_spans",
        "reviewed_at",
        "request_sha256",
        "artifact_sha256"
      ],
      "properties": {
        "item_id": {
          "type": "string",
          "minLength": 1,
          "description": "Blinded item identifier; must not encode baseline/candidate labels."
        },
        "reviewer_id": {
          "type": "string",
          "minLength": 1,
          "description": "Pseudonymous reviewer identifier."
        },
        "rubric_id": {"type": "string", "minLength": 1},
        "rubric_version": {"type": "string", "minLength": 1},
        "decision": {
          "enum": ["A", "B", "tie", "uncertain"]
        },
        "evidence_spans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["turn_id", "span_id"],
            "properties": {
              "turn_id": {"type": ["string", "integer"]},
              "span_id": {"type": "string", "minLength": 1},
              "note_code": {"type": "string", "minLength": 1}
            }
          }
        },
        "reviewed_at": {
          "type": "string",
          "minLength": 1,
          "description": "ISO-8601 timestamp."
        },
        "request_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifact_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      },
      "not": {
        "anyOf": [
          {"required": ["baseline"]},
          {"required": ["candidate"]},
          {"required": ["side"]},
          {"required": ["baseline_label"]},
          {"required": ["candidate_label"]}
        ]
      }
    }
  }
}
