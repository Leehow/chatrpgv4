{
  "schema_version": 1,
  "eval_spec": "eval-spec-v1",
  "case_family": "long-memory",
  "description": "Versioned 25/50-turn continuity lanes with restart, recall anchors, and checkpoint integrity. Repository stores the verification contract only; gameplay evidence is supplied per run.",
  "lanes": [
