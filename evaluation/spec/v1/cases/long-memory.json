          "require_session_identity_continuity": true
        },
        "accepted_turns": {
          "monotonic": true,
          "exact_count": 25
        },
        "recall_anchors": [
          "inventory",
          "injury",
          "san",
          "relationship",
          "clue",
          "unresolved_thread"
        ],
        "checkpoint_integrity": {
          "pre_post_hash_match_required": true
        },
        "evidence_eligibility": {
          "required_fields": ["evidence_class", "eligible"]
        },
        "secret_leakage_audit": {
          "required": true,
          "source": "structured_audit_references",
          "forbid_prose_scanning": true
        }
      }
    },
