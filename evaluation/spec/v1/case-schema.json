{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chatrpgv4.local/evaluation/spec/v1/case-schema.json",
  "title": "COC Evaluation Case Registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "eval_spec", "registry_version", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "eval_spec": {"const": "eval-spec-v1"},
    "registry_version": {"type": "string", "minLength": 1},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "description",
        "kind",
        "suites",
        "gate",
        "required_capabilities",
        "command",
        "evidence_requirements"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
        },
        "description": {"type": "string", "minLength": 1},
        "kind": {
          "enum": ["pytest_node", "python_command", "artifact_verification"]
        },
        "suites": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["smoke", "pr", "nightly", "release", "diagnostic"]
          }
        },
        "gate": {"enum": ["hard", "soft", "diagnostic"]},
        "required_capabilities": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "command": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence_requirements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
